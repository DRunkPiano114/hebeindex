---
import '../styles/global.css'
import { strings } from '../i18n/strings'

interface Props {
  title?: string
  hasSidebar?: boolean
}

const { title = strings.siteName, hasSidebar = true } = Astro.props
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="044f05db-dd01-432a-ad61-13833e25a4c2"></script>
  </head>
  <body>
    <div class:list={['app-layout', { 'has-sidebar': hasSidebar }]}>
      <slot name="sidebar" />
      <div class="app-main">
        <slot />
      </div>
    </div>
  </body>
</html>

<style>
  .app-layout {
    display: grid;
    grid-template-columns: 1fr;
    height: 100vh;
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
  }

  .app-layout.has-sidebar {
    grid-template-columns: 220px 1fr;
  }

  .app-main {
    padding: 0 32px 24px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .app-layout.has-sidebar {
      grid-template-columns: 1fr;
    }

    .app-main {
      padding: 0 16px;
    }
  }
</style>
