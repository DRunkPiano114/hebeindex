---
import '../styles/global.css'
import { strings } from '../i18n/strings'

interface Props {
  title?: string
}

const { title = strings.defaultTitle } = Astro.props
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="app-layout">
      <slot name="sidebar" />
      <div class="app-main">
        <slot />
        <footer class="app-footer">
          {strings.footerText} &nbsp;·&nbsp; {strings.footerUpdate}
        </footer>
      </div>
    </div>
  </body>
</html>

<style>
  .app-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 100vh;
    max-width: 1200px;
    margin: 0 auto;
  }

  .app-main {
    padding: 0 32px;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .app-footer {
    margin-top: auto;
    padding: 24px 0;
    text-align: center;
    border-top: 1px solid var(--divider);
    color: var(--text-secondary);
    font-size: 12px;
  }

  @media (max-width: 768px) {
    .app-layout {
      grid-template-columns: 1fr;
    }

    .app-main {
      padding: 0 16px;
    }
  }
</style>
