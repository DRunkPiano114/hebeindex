---
import { strings } from '../i18n/strings'

interface NavItem {
  key: string
  label: string
  sub: string
  count: number
}

interface Props {
  items: NavItem[]
  total: number
  activeKey?: string
  artistName: string
  artistEnglish: string
}

const { items, total, activeKey = items[0]?.key, artistName, artistEnglish } = Astro.props
---

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="font-display" style="font-size: 28px; font-weight: 400; line-height: 1.2; letter-spacing: -0.01em;">
      {artistName}
    </div>
    <div class="font-display" style="font-size: 14px; color: var(--text-secondary); font-style: italic; margin-top: 2px;">
      {artistEnglish} Archive
    </div>
    <div style="font-size: 11px; color: var(--text-secondary); margin-top: 8px; letter-spacing: 0.04em;">
      共收錄 <span class="font-display" style="font-size: 14px; color: var(--accent); font-weight: 500;">{total}</span> 條
    </div>
  </div>

  <nav class="sidebar-nav">
    {items.map(({ key, label, sub, count }) => (
      <a
        href={`#${key}`}
        class:list={['sidebar-item', { active: key === activeKey }]}
        data-key={key}
      >
        <div>
          <div class="sidebar-item-label">{label}</div>
          <div class="sidebar-item-sub">{sub}</div>
        </div>
        <span class="sidebar-item-count">{count}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-footer-title">{strings.feedbackTitle}</div>
    <div class="sidebar-footer-desc">{strings.feedbackDesc}</div>
    <div class="sidebar-footer-links">
      <a class="sidebar-footer-btn" href="https://github.com/DRunkPiano114/hebeindex/issues/new" target="_blank" rel="noopener">
        {strings.feedbackGithub}
      </a>
      <a class="sidebar-footer-btn" href="https://docs.google.com/forms/d/e/1FAIpQLSfHbcYJ8m76x9RDZDkE3NERTlxDb7okm8o5-kfP4x8S4m2OsQ/viewform" target="_blank" rel="noopener">
        {strings.feedbackForm}
      </a>
    </div>
  </div>
</aside>

<!-- Mobile horizontal tab bar -->
<nav class="mobile-tabs">
  {items.map(({ key, label, count }) => (
    <a
      href={`#${key}`}
      class:list={['mobile-tab', { active: key === activeKey }]}
      data-key={key}
    >
      {label} <span class="mobile-tab-count">{count}</span>
    </a>
  ))}
</nav>

<style>
  .sidebar {
    background: var(--sidebar-bg);
    border-right: 1px solid var(--divider);
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .sidebar-brand {
    padding: 32px 20px 24px;
    border-bottom: 1px solid var(--divider);
  }

  .sidebar-nav {
    flex: 1;
    padding: 12px 0;
  }

  .sidebar-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--divider);
  }

  .sidebar-footer-title {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .sidebar-footer-desc {
    font-size: 10px;
    color: var(--text-secondary);
    opacity: 0.7;
    margin-bottom: 6px;
  }

  .sidebar-footer-links {
    display: flex;
    gap: 8px;
  }

  .sidebar-footer-btn {
    flex: 1;
    display: block;
    padding: 6px 0;
    border: 1px solid var(--accent);
    border-radius: 6px;
    font-size: 10px;
    text-align: center;
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .sidebar-footer-btn:hover {
    background-color: var(--accent);
    color: #fff;
  }


  .sidebar-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    border-left: 3px solid transparent;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    text-decoration: none;
    color: inherit;
  }

  .sidebar-item:hover {
    background-color: #F0EDE8;
    color: inherit;
  }

  .sidebar-item.active {
    border-left-color: var(--accent);
    background-color: rgba(180, 83, 9, 0.06);
  }

  .sidebar-item-label {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
  }

  .sidebar-item-sub {
    font-size: 11px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
    margin-top: 1px;
  }

  .sidebar-item-count {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: var(--text-secondary);
    background: rgba(0,0,0,0.04);
    padding: 1px 8px;
    border-radius: 10px;
    flex-shrink: 0;
  }

  /* Mobile tabs */
  .mobile-tabs {
    display: none;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .mobile-tabs {
      display: flex;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      gap: 0;
      padding: 0 12px;
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--divider);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .mobile-tab {
      flex-shrink: 0;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
      text-decoration: none;
      border-bottom: 2px solid transparent;
      white-space: nowrap;
      transition: color 0.15s ease, border-color 0.15s ease;
    }

    .mobile-tab:hover {
      color: var(--text-primary);
    }

    .mobile-tab.active {
      color: var(--text-primary);
      border-bottom-color: var(--accent);
    }

    .mobile-tab-count {
      font-size: 11px;
      color: var(--text-secondary);
      margin-left: 2px;
    }
  }
</style>
