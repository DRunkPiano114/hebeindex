---
import Layout from '../components/Layout.astro'
import Sidebar from '../components/Sidebar.astro'
import ContentTable from '../components/ContentTable'
import { loadCategory } from '../data/loader'
import { strings } from '../i18n/strings'

const catKeys = ['personalMV', 'sheMV', 'concerts', 'variety', 'interviews', 'singles', 'collabs'] as const
const fileIds: Record<string, number> = { personalMV: 2, sheMV: 7, concerts: 4, variety: 5, interviews: 6, singles: 3, collabs: 8 }

const categories = catKeys.map(key => ({
  key,
  ...strings.categories[key],
  fileId: fileIds[key],
}))

const data = categories.map(c => ({
  ...c,
  items: loadCategory(c.fileId),
}))

const total = data.reduce((sum, c) => sum + c.items.length, 0)

const navItems = data.map(c => ({
  key: c.key,
  label: c.label,
  sub: c.sub,
  count: c.items.length,
}))
---

<Layout title={strings.siteTitle}>
  <Sidebar slot="sidebar" items={navItems} total={total} />

  {data.map((cat, i) => (
    <div
      class:list={['category-panel', { active: i === 0 }]}
      id={`panel-${cat.key}`}
      data-category={cat.key}
    >
      <section style="padding: 24px 0 16px; flex-shrink: 0;">
        <h2 class="font-display" style="font-size: 28px; font-weight: 400; margin-bottom: 4px;">
          {cat.label}
        </h2>
        <p style="color: var(--text-secondary); font-size: 13px; letter-spacing: 0.03em;">
          {cat.sub}
        </p>
      </section>

      {i === 0 ? (
        <ContentTable client:load items={cat.items} searchPlaceholder={cat.search} />
      ) : (
        <ContentTable client:idle items={cat.items} searchPlaceholder={cat.search} />
      )}
    </div>
  ))}
</Layout>

<script>
  function switchCategory(key: string, pushState = true) {
    // Update panels
    document.querySelectorAll('.category-panel').forEach(el => {
      const panel = el as HTMLElement
      if (panel.dataset.category === key) {
        panel.classList.add('active')
      } else {
        panel.classList.remove('active')
      }
    })

    // Update sidebar items
    document.querySelectorAll('.sidebar-item').forEach(el => {
      const link = el as HTMLElement
      if (link.dataset.key === key) {
        link.classList.add('active')
      } else {
        link.classList.remove('active')
      }
    })

    // Update mobile tabs
    document.querySelectorAll('.mobile-tab').forEach(el => {
      const tab = el as HTMLElement
      if (tab.dataset.key === key) {
        tab.classList.add('active')
      } else {
        tab.classList.remove('active')
      }
    })

    // Update URL hash
    if (pushState) {
      history.pushState(null, '', `#${key}`)
    }
  }

  function getKeyFromHash(): string | null {
    const hash = window.location.hash.slice(1)
    if (!hash) return null
    const panel = document.getElementById(`panel-${hash}`)
    return panel ? hash : null
  }

  // Intercept sidebar/tab clicks
  document.querySelectorAll('.sidebar-item, .mobile-tab').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault()
      const key = (el as HTMLElement).dataset.key
      if (key) switchCategory(key)
    })
  })

  // Handle initial hash
  const initialKey = getKeyFromHash()
  if (initialKey) {
    switchCategory(initialKey, false)
  }

  // Handle browser back/forward
  window.addEventListener('popstate', () => {
    const key = getKeyFromHash()
    if (key) {
      switchCategory(key, false)
    } else {
      // Default to first category
      const first = document.querySelector('.category-panel') as HTMLElement
      if (first?.dataset.category) {
        switchCategory(first.dataset.category, false)
      }
    }
  })
</script>

<style>
  .category-panel {
    display: none;
    opacity: 0;
    transform: translateY(4px);
  }

  .category-panel.active {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex: 1;
    animation: fadeIn 0.2s ease forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
