---
import Layout from '../components/Layout.astro'
import { loadAllArtists } from '../data/loader'
import { strings } from '../i18n/strings'

const artists = loadAllArtists()
---

<Layout title={strings.siteName} hasSidebar={false}>
  <div class="landing">
    <header class="landing-header">
      <h1 class="font-display" style="font-size: 36px; font-weight: 400; letter-spacing: -0.01em;">
        {strings.siteName}
      </h1>
      <p style="color: var(--text-secondary); font-size: 14px; margin-top: 4px;">
        {strings.footerText}
      </p>
    </header>

    <div class="artist-grid">
      {artists.map(artist => (
        <a href={`/${artist.slug}/`} class="artist-card">
          <div class="artist-card-name font-display">{artist.names.primary}</div>
          <div class="artist-card-english">{artist.names.english}</div>
          <div class="artist-card-meta">
            {[artist.birthYear, artist.genre, artist.awards[0]].filter(Boolean).join(' · ')}
          </div>
          <div class="artist-card-cats">
            {artist.categories.length} 分類
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .landing {
    padding: 48px 32px;
    max-width: 800px;
    margin: 0 auto;
    overflow-y: auto;
    height: 100%;
  }

  .landing-header {
    margin-bottom: 40px;
  }

  .artist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .artist-card {
    display: block;
    padding: 28px 24px;
    background: var(--sidebar-bg);
    border: 1px solid var(--divider);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .artist-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(180, 83, 9, 0.08);
  }

  .artist-card-name {
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .artist-card-english {
    font-size: 14px;
    color: var(--text-secondary);
    font-style: italic;
    margin-top: 2px;
  }

  .artist-card-meta {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 12px;
    letter-spacing: 0.02em;
  }

  .artist-card-cats {
    font-size: 11px;
    color: var(--accent);
    font-weight: 500;
    margin-top: 8px;
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .landing {
      padding: 24px 16px;
    }

    .artist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
