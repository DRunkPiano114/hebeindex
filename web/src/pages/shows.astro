---
import Layout from '../components/Layout.astro'
import ContentTable from '../components/ContentTable'
import { loadCategory } from '../data/loader'

const variety = loadCategory(5)
const interviews = loadCategory(6)
---

<Layout title="节目与访谈 · 田馥甄档案库">
  <section style="padding: 48px 0 32px;">
    <h2 class="font-display" style="font-size: 32px; font-weight: 400; margin-bottom: 4px;">节目与访谈</h2>
    <p style="color: var(--text-secondary); font-size: 13px;">综艺节目 · 采访访谈</p>
  </section>

  <div id="tab-nav" style="display: flex; gap: 0; border-bottom: 1px solid var(--divider); margin-bottom: 32px;">
    <button id="tab-variety" onclick="switchTab('variety')"
      style="padding: 10px 20px; border: none; background: none; font-size: 14px; cursor: pointer; border-bottom: 2px solid var(--accent); color: var(--text-primary); transition: all 0.15s ease;">
      综艺节目 <span style="color: var(--text-secondary); font-size: 12px;">{variety.length}</span>
    </button>
    <button id="tab-interviews" onclick="switchTab('interviews')"
      style="padding: 10px 20px; border: none; background: none; font-size: 14px; cursor: pointer; border-bottom: 2px solid transparent; color: var(--text-secondary); transition: all 0.15s ease;">
      采访访谈 <span style="color: var(--text-secondary); font-size: 12px;">{interviews.length}</span>
    </button>
  </div>

  <div id="panel-variety">
    <ContentTable client:load items={variety} searchPlaceholder="搜索综艺节目..." />
  </div>
  <div id="panel-interviews" style="display: none;">
    <ContentTable client:load items={interviews} searchPlaceholder="搜索采访访谈..." />
  </div>
</Layout>

<script>
  function switchTab(tab: string) {
    const variety = document.getElementById('panel-variety')!
    const interviews = document.getElementById('panel-interviews')!
    const tabVariety = document.getElementById('tab-variety')!
    const tabInterviews = document.getElementById('tab-interviews')!

    if (tab === 'variety') {
      variety.style.display = 'block'
      interviews.style.display = 'none'
      tabVariety.style.borderBottomColor = 'var(--accent)'
      tabVariety.style.color = 'var(--text-primary)'
      tabInterviews.style.borderBottomColor = 'transparent'
      tabInterviews.style.color = 'var(--text-secondary)'
    } else {
      variety.style.display = 'none'
      interviews.style.display = 'block'
      tabVariety.style.borderBottomColor = 'transparent'
      tabVariety.style.color = 'var(--text-secondary)'
      tabInterviews.style.borderBottomColor = 'var(--accent)'
      tabInterviews.style.color = 'var(--text-primary)'
    }
  }

  if (window.location.hash === '#interviews') {
    switchTab('interviews')
  }

  (window as any).switchTab = switchTab
</script>
