---
import Layout from '../components/Layout.astro'
import ContentTable from '../components/ContentTable'
import { loadCategory } from '../data/loader'

const personalMV = loadCategory(2)
const sheMV = loadCategory(7)
---

<Layout title="MV · 田馥甄档案库">
  <section style="padding: 48px 0 32px;">
    <h2 class="font-display" style="font-size: 32px; font-weight: 400; margin-bottom: 4px;">MV</h2>
    <p style="color: var(--text-secondary); font-size: 13px;">音乐视频收录</p>
  </section>

  <!-- Tab nav -->
  <div id="tab-nav" style="display: flex; gap: 0; border-bottom: 1px solid var(--divider); margin-bottom: 32px;">
    <button id="tab-personal" onclick="switchTab('personal')"
      style="padding: 10px 20px; border: none; background: none; font-size: 14px; cursor: pointer; border-bottom: 2px solid var(--accent); color: var(--text-primary); transition: all 0.15s ease;">
      个人 MV <span style="color: var(--text-secondary); font-size: 12px;">{personalMV.length}</span>
    </button>
    <button id="tab-she" onclick="switchTab('she')"
      style="padding: 10px 20px; border: none; background: none; font-size: 14px; cursor: pointer; border-bottom: 2px solid transparent; color: var(--text-secondary); transition: all 0.15s ease;">
      S.H.E MV <span style="color: var(--text-secondary); font-size: 12px;">{sheMV.length}</span>
    </button>
  </div>

  <div id="panel-personal">
    <ContentTable client:load items={personalMV} searchPlaceholder="搜索个人 MV..." />
  </div>
  <div id="panel-she" style="display: none;">
    <ContentTable client:load items={sheMV} searchPlaceholder="搜索 S.H.E MV..." />
  </div>
</Layout>

<script>
  function switchTab(tab: string) {
    const personal = document.getElementById('panel-personal')!
    const she = document.getElementById('panel-she')!
    const tabPersonal = document.getElementById('tab-personal')!
    const tabShe = document.getElementById('tab-she')!

    if (tab === 'personal') {
      personal.style.display = 'block'
      she.style.display = 'none'
      tabPersonal.style.borderBottomColor = 'var(--accent)'
      tabPersonal.style.color = 'var(--text-primary)'
      tabShe.style.borderBottomColor = 'transparent'
      tabShe.style.color = 'var(--text-secondary)'
    } else {
      personal.style.display = 'none'
      she.style.display = 'block'
      tabPersonal.style.borderBottomColor = 'transparent'
      tabPersonal.style.color = 'var(--text-secondary)'
      tabShe.style.borderBottomColor = 'var(--accent)'
      tabShe.style.color = 'var(--text-primary)'
    }
  }

  // Handle #she anchor
  if (window.location.hash === '#she') {
    switchTab('she')
  }

  // Expose globally for inline onclick
  (window as any).switchTab = switchTab
</script>
