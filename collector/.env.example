# ====================================================
# 田馥甄 Hebe Content Collection Agent — API Keys
# ====================================================
# 复制本文件为 .env，填入你的 API key

# 1. OpenRouter API Key（必填，统一网关，一个 key 访问所有 provider）
#    获取地址：https://openrouter.ai/keys
#    充值后限流门槛大幅提升，按实际用量计费。
#    路由顺序：Gemini 3.1 Pro Preview → Claude Sonnet → OpenAI（自动 fallback）
OPENROUTER_API_KEY=sk-or-...

# 2. YouTube Data API v3 Keys（免费，支持最多 3 个 key 自动轮换）
#    申请步骤（每个 key 对应一个独立的 Google Cloud 项目）：
#    a) 访问 https://console.cloud.google.com
#    b) 顶部项目下拉 → 新建项目（为每个 key 建一个新项目）
#    c) 搜索并启用 "YouTube Data API v3"
#    d) 前往「凭据」→「创建凭据」→「API 密钥」→ 复制
#
#    每个 key 每日免费配额：10,000 units
#    3 个 key 合计：30,000 units/天（本任务约消耗 8,000，绰绰有余）
#    配额耗尽时自动切换到下一个 key，无需手动干预
#
YOUTUBE_API_KEY=AIza...      # 必填（Google Cloud 项目 1）
YOUTUBE_API_KEY_2=AIza...    # 可选（Google Cloud 项目 2）
YOUTUBE_API_KEY_3=AIza...    # 可选（Google Cloud 项目 3）

# 3. Serper.dev API Key（Google 搜索，每月2500次免费）
#    申请地址：https://serper.dev（注册即送2500次免费额度）
SERPER_API_KEY=...

# Bilibili 不需要 API key，直接访问公开接口
